{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the desktop widget and settings windows",
  "windows": ["main", "settings", "account-editor"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "opener:default",
    "store:default",
    "window-state:default"
  ]
}
